{
  "name": "oddlyalive-demos",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:assets": "node prepare-assets.mjs",
    "build:bundle": "npm run prepare:assets && esbuild app.js --bundle --format=iife --target=es2020 --outfile=app.bundle.js",
    "dev": "npx --yes hyperframes@0.7.66 preview",
    "check": "npm run build:bundle && npx --yes hyperframes@0.7.66 check",
    "render": "npm run build:bundle && npx --yes hyperframes@0.7.66 render",
    "publish": "npx --yes hyperframes@0.7.66 publish"
  },
  "dependencies": {
    "gsap": "^3.14.2"
  },
  "devDependencies": {
    "esbuild": "^0.25.6"
  }
}
